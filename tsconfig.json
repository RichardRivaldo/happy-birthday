{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "typeRoots": ["./node_modules/@types"],
    "baseUrl": ".",
    "paths": {
      "@app/*": ["app/*"],
      "@config/*": ["src/config/*"],
      "@shared/*": ["src/shared/*"],
      "@domains/*": ["src/domains/*"],
      "@outbounds/*": ["src/outbounds/*"]
    }
  },
  "include": ["app/**/*", "src/**/*"],
  "exclude": ["node_modules", "dist"]
}
