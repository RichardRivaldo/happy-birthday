{
	"name": "happy-birthday",
	"version": "1.0.0",
	"description": "Birthday Reminder Service — sends Happy Birthday at 9 AM in the user's local timezone.",
	"main": "dist/app/main.js",
	"scripts": {
		"dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register app/main.ts",
		"build": "tsc && tsc-alias",
		"start": "node dist/app/main.js",
		"test": "jest --runInBand --forceExit",
		"test:coverage": "jest --runInBand --forceExit --coverage",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check --write ."
	},
	"dependencies": {
		"agenda": "^5.0.0",
		"dotenv": "^16.4.5",
		"express": "^4.19.2",
		"luxon": "^3.4.4",
		"mongoose": "^8.4.1",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@types/express": "^4.17.21",
		"@types/jest": "^29.5.12",
		"@types/luxon": "^3.4.2",
		"@types/node": "^20.14.2",
		"@types/supertest": "^6.0.2",
		"jest": "^29.7.0",
		"supertest": "^7.0.0",
		"ts-jest": "^29.1.4",
		"ts-node": "^10.9.2",
		"ts-node-dev": "^2.0.0",
		"tsc-alias": "^1.8.16",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.4.5"
	}
}
